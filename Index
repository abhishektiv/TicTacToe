<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Tic Tac Toe</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --surface: #12121a;
      --border: #2a2a3a;
      --x-color: #ff4d6d;
      --o-color: #00d4ff;
      --x-glow: rgba(255, 77, 109, 0.5);
      --o-glow: rgba(0, 212, 255, 0.5);
      --text: #e8e8f0;
      --muted: #555570;
      --accent: #f0c040;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Mono', monospace;
      overflow: hidden;
      touch-action: manipulation;
    }

    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100dvh;
      padding: 20px 16px;
      position: relative;
    }

    /* Background grid lines */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 360px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }

    /* Header */
    .header {
      text-align: center;
    }

    .title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.8rem, 12vw, 3.6rem);
      letter-spacing: 6px;
      line-height: 1;
      background: linear-gradient(135deg, var(--x-color), var(--o-color));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .subtitle {
      font-size: 0.65rem;
      letter-spacing: 4px;
      color: var(--muted);
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* Score Board */
    .scoreboard {
      display: flex;
      align-items: center;
      gap: 0;
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      background: var(--surface);
    }

    .score-block {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 14px 10px;
      gap: 4px;
      position: relative;
      transition: background 0.3s;
    }

    .score-block.active-turn {
      background: rgba(255,255,255,0.04);
    }

    .score-block::after {
      content: '▶';
      position: absolute;
      bottom: 6px;
      font-size: 0.5rem;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .score-block.active-turn::after {
      opacity: 1;
    }

    .score-block:first-child::after { color: var(--x-color); }
    .score-block:last-child::after { color: var(--o-color); }

    .score-divider {
      width: 1px;
      height: 50px;
      background: var(--border);
    }

    .score-label {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 2px;
    }

    .score-label.x { color: var(--x-color); text-shadow: 0 0 12px var(--x-glow); }
    .score-label.o { color: var(--o-color); text-shadow: 0 0 12px var(--o-glow); }
    .score-label.draw { color: var(--accent); }

    .score-num {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
    }

    .score-tag {
      font-size: 0.55rem;
      letter-spacing: 2px;
      color: var(--muted);
      text-transform: uppercase;
    }

    /* Status */
    .status {
      font-size: 0.75rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
      height: 20px;
      text-align: center;
      transition: all 0.3s;
    }

    .status.win-x { color: var(--x-color); text-shadow: 0 0 10px var(--x-glow); }
    .status.win-o { color: var(--o-color); text-shadow: 0 0 10px var(--o-glow); }
    .status.draw-status { color: var(--accent); }

    /* Board */
    .board {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      width: 100%;
      aspect-ratio: 1;
    }

    .cell {
      aspect-ratio: 1;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: border-color 0.2s, transform 0.1s, background 0.2s;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }

    .cell:active:not(.taken) {
      transform: scale(0.94);
      background: rgba(255,255,255,0.05);
    }

    .cell.taken { cursor: default; }

    .cell.highlight-win {
      border-color: transparent;
      animation: pulseWin 0.8s ease-in-out infinite alternate;
    }

    .cell.highlight-win.x { background: rgba(255,77,109,0.15); border-color: var(--x-color); }
    .cell.highlight-win.o { background: rgba(0,212,255,0.15); border-color: var(--o-color); }

    @keyframes pulseWin {
      from { box-shadow: 0 0 0 0 transparent; }
      to { box-shadow: 0 0 16px 2px var(--x-glow); }
    }

    .cell.highlight-win.o { animation-name: pulseWinO; }
    @keyframes pulseWinO {
      from { box-shadow: 0 0 0 0 transparent; }
      to { box-shadow: 0 0 16px 2px var(--o-glow); }
    }

    /* X and O marks */
    .mark {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2rem, 11vw, 3rem);
      line-height: 1;
      opacity: 0;
      transform: scale(0.3) rotate(-20deg);
      transition: opacity 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
                  transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .mark.show {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }

    .mark.x {
      color: var(--x-color);
      text-shadow: 0 0 20px var(--x-glow);
    }

    .mark.o {
      color: var(--o-color);
      text-shadow: 0 0 20px var(--o-glow);
    }

    /* Buttons */
    .btn-row {
      display: flex;
      gap: 10px;
      width: 100%;
    }

    .btn {
      flex: 1;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface);
      color: var(--text);
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s;
      -webkit-tap-highlight-color: transparent;
    }

    .btn:active { transform: scale(0.96); }

    .btn-primary {
      background: linear-gradient(135deg, rgba(255,77,109,0.2), rgba(0,212,255,0.2));
      border-color: rgba(255,255,255,0.15);
      color: #fff;
    }

    .btn-primary:hover { background: linear-gradient(135deg, rgba(255,77,109,0.35), rgba(0,212,255,0.35)); }

    /* Mode toggle */
    .mode-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.6rem;
      letter-spacing: 2px;
      color: var(--muted);
      text-transform: uppercase;
    }

    .toggle {
      position: relative;
      width: 40px;
      height: 22px;
      background: var(--border);
      border-radius: 11px;
      cursor: pointer;
      transition: background 0.3s;
      -webkit-tap-highlight-color: transparent;
    }

    .toggle.on { background: linear-gradient(135deg, var(--x-color), var(--o-color)); }

    .toggle::after {
      content: '';
      position: absolute;
      top: 3px;
      left: 3px;
      width: 16px;
      height: 16px;
      background: #fff;
      border-radius: 50%;
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .toggle.on::after { transform: translateX(18px); }

    /* Ripple */
    .ripple {
      position: absolute;
      border-radius: 50%;
      width: 10px;
      height: 10px;
      background: rgba(255,255,255,0.2);
      transform: scale(0);
      animation: rippleAnim 0.4s ease-out forwards;
      pointer-events: none;
    }

    @keyframes rippleAnim {
      to { transform: scale(20); opacity: 0; }
    }
  </style>
</head>
<body>
<div class="container">

  <div class="header">
    <div class="title">TIC TAC TOE</div>
    <div class="subtitle">2 players · local play</div>
  </div>

  <div class="scoreboard">
    <div class="score-block active-turn" id="scoreX">
      <div class="score-label x">X</div>
      <div class="score-num" id="scoreXNum">0</div>
      <div class="score-tag">Player 1</div>
    </div>
    <div class="score-divider"></div>
    <div class="score-block" id="scoreDraw">
      <div class="score-label draw">—</div>
      <div class="score-num" id="scoreDrawNum">0</div>
      <div class="score-tag">Draw</div>
    </div>
    <div class="score-divider"></div>
    <div class="score-block" id="scoreO">
      <div class="score-label o">O</div>
      <div class="score-num" id="scoreONum">0</div>
      <div class="score-tag">Player 2</div>
    </div>
  </div>

  <div class="status" id="status">Player X's turn</div>

  <div class="board" id="board">
    <!-- Cells injected by JS -->
  </div>

  <div class="btn-row">
    <button class="btn btn-primary" id="btnRestart">↺ &nbsp;New Game</button>
    <button class="btn" id="btnReset">Reset Scores</button>
  </div>

  <div class="mode-row">
    <span>2P</span>
    <div class="toggle" id="modeToggle" title="Toggle AI mode"></div>
    <span>vs AI</span>
  </div>

</div>

<script>
  const WIN_LINES = [
    [0,1,2],[3,4,5],[6,7,8],
    [0,3,6],[1,4,7],[2,5,8],
    [0,4,8],[2,4,6]
  ];

  let board = Array(9).fill(null);
  let current = 'X';
  let gameOver = false;
  let scores = { X: 0, O: 0, D: 0 };
  let vsAI = false;

  const boardEl = document.getElementById('board');
  const statusEl = document.getElementById('status');
  const scoreXNum = document.getElementById('scoreXNum');
  const scoreONum = document.getElementById('scoreONum');
  const scoreDrawNum = document.getElementById('scoreDrawNum');
  const scoreXEl = document.getElementById('scoreX');
  const scoreOEl = document.getElementById('scoreO');
  const modeToggle = document.getElementById('modeToggle');

  // Build board cells
  for (let i = 0; i < 9; i++) {
    const cell = document.createElement('div');
    cell.className = 'cell';
    cell.dataset.i = i;
    cell.innerHTML = `<span class="mark" id="mark${i}"></span>`;
    cell.addEventListener('click', onCellClick);
    boardEl.appendChild(cell);
  }

  function onCellClick(e) {
    const i = parseInt(e.currentTarget.dataset.i);
    if (gameOver || board[i]) return;
    if (vsAI && current === 'O') return;

    addRipple(e.currentTarget, e);
    makeMove(i);

    if (!gameOver && vsAI && current === 'O') {
      setTimeout(aiMove, 400);
    }
  }

  function makeMove(i) {
    board[i] = current;
    const markEl = document.getElementById(`mark${i}`);
    markEl.textContent = current;
    markEl.className = `mark ${current.toLowerCase()} show`;
    document.querySelector(`[data-i="${i}"]`).classList.add('taken');

    const win = checkWin();
    if (win) {
      highlightWin(win);
      scores[current]++;
      updateScores();
      setStatus(`Player ${current} wins! 🎉`, current === 'X' ? 'win-x' : 'win-o');
      gameOver = true;
      return;
    }

    if (board.every(Boolean)) {
      scores.D++;
      updateScores();
      setStatus("It's a draw!", 'draw-status');
      gameOver = true;
      return;
    }

    current = current === 'X' ? 'O' : 'X';
    updateTurnIndicator();
    setStatus(vsAI && current === 'O' ? 'AI is thinking...' : `Player ${current}'s turn`, '');
  }

  function aiMove() {
    const best = getBestMove();
    makeMove(best);
  }

  function getBestMove() {
    // Win or block first
    for (const line of WIN_LINES) {
      const [a,b,c] = line;
      // Try to win
      if (board[a]==='O' && board[b]==='O' && !board[c]) return c;
      if (board[a]==='O' && board[c]==='O' && !board[b]) return b;
      if (board[b]==='O' && board[c]==='O' && !board[a]) return a;
    }
    for (const line of WIN_LINES) {
      const [a,b,c] = line;
      // Block X
      if (board[a]==='X' && board[b]==='X' && !board[c]) return c;
      if (board[a]==='X' && board[c]==='X' && !board[b]) return b;
      if (board[b]==='X' && board[c]==='X' && !board[a]) return a;
    }
    // Center
    if (!board[4]) return 4;
    // Corners
    const corners = [0,2,6,8].filter(i => !board[i]);
    if (corners.length) return corners[Math.floor(Math.random()*corners.length)];
    // Any free
    const free = board.map((v,i)=>v?-1:i).filter(i=>i>=0);
    return free[Math.floor(Math.random()*free.length)];
  }

  function checkWin() {
    for (const line of WIN_LINES) {
      const [a,b,c] = line;
      if (board[a] && board[a]===board[b] && board[a]===board[c]) return line;
    }
    return null;
  }

  function highlightWin(line) {
    line.forEach(i => {
      const cell = document.querySelector(`[data-i="${i}"]`);
      cell.classList.add('highlight-win', current.toLowerCase());
    });
  }

  function setStatus(msg, cls) {
    statusEl.textContent = msg;
    statusEl.className = 'status ' + (cls || '');
  }

  function updateTurnIndicator() {
    scoreXEl.classList.toggle('active-turn', current === 'X');
    scoreOEl.classList.toggle('active-turn', current === 'O');
  }

  function updateScores() {
    scoreXNum.textContent = scores.X;
    scoreONum.textContent = scores.O;
    scoreDrawNum.textContent = scores.D;
  }

  function addRipple(el, e) {
    const rect = el.getBoundingClientRect();
    const r = document.createElement('div');
    r.className = 'ripple';
    const x = (e.clientX || rect.left + rect.width/2) - rect.left;
    const y = (e.clientY || rect.top + rect.height/2) - rect.top;
    r.style.left = x - 5 + 'px';
    r.style.top = y - 5 + 'px';
    el.appendChild(r);
    r.addEventListener('animationend', () => r.remove());
  }

  function restartGame() {
    board = Array(9).fill(null);
    current = 'X';
    gameOver = false;
    document.querySelectorAll('.cell').forEach(c => {
      c.className = 'cell';
    });
    document.querySelectorAll('.mark').forEach(m => {
      m.className = 'mark';
      m.textContent = '';
    });
    updateTurnIndicator();
    setStatus(vsAI ? "Player X's turn" : "Player X's turn", '');
  }

  document.getElementById('btnRestart').addEventListener('click', restartGame);
  document.getElementById('btnReset').addEventListener('click', () => {
    scores = { X: 0, O: 0, D: 0 };
    updateScores();
    restartGame();
  });

  modeToggle.addEventListener('click', () => {
    vsAI = !vsAI;
    modeToggle.classList.toggle('on', vsAI);
    document.querySelector('.subtitle').textContent = vsAI ? '1 player · vs AI' : '2 players · local play';
    document.getElementById('scoreO').querySelector('.score-tag').textContent = vsAI ? 'AI' : 'Player 2';
    restartGame();
  });

  updateTurnIndicator();
</script>
</body>
</html>
